@page
@model Book_An_Appointment1.Pages.Appointment.IndexModel
@{
    ViewData["Title"] = "Book Appointment";
}

<form method="post" id="appointmentForm">
    @Html.AntiForgeryToken()

    <input type="hidden" name="handler" id="formHandler" value="" />
    <input type="hidden" name="selectedSlotStart" id="hdnSelectedSlotStart" value="" />
    <input type="hidden" name="selectedSlotEnd" id="hdnSelectedSlotEnd" value="" />
    <div class="container mt-5">

        @* Error Message *@

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger mb-4">
                <strong>Error:</strong> @Model.ErrorMessage
            </div>
        }
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mb-4">
                <ul class="mb-0">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }
        <!-- Tracker -->
        <div class="wizard-track mb-5 d-flex justify-content-between">

            <div class="step active">
                Appointment
            </div>

            <div class="step-line"></div>

            <div class="step">
                Patient Details
            </div>

            <div class="step-line"></div>

            <div class="step">
                Confirmation
            </div>

            <div class="step-line"></div>

            <div class="step">
                Payment
            </div>

        </div>

        <!-- Dropdowns -->
        <div class="row g-4">

            <!-- Facility -->
            <div class="col-md-4">
                <label class="form-label fw-bold">
                    Facility
                </label>

                <select name="FacilityId"
                        id="facilityDropdown"
                        class="form-select select2">

                    <option value="">
                        Select Facility
                    </option>

                    @foreach (var item in Model.Wizard.Facilities)
                    {
                        <option value="@item.FacilityId">
                            @(item.FacilityName ?? "N/A")
                        </option>
                    }

                </select>
            </div>

            <!-- Speciality -->
            <div class="col-md-4">
                <label class="form-label fw-bold">
                    Speciality
                </label>

                <select name="SpecialityId"
                        id="specialityDropdown"
                        class="form-select select2">

                    <option value="">
                        Search Speciality
                    </option>

                    @foreach (var item in Model.Wizard.Specialities)
                    {
                        <option value="@item.Id">
                            @(item.SpecialisationName ?? "N/A")
                        </option>
                    }

                </select>
            </div>

            <!-- Doctor -->
            <div class="col-md-4">
                <label class="form-label fw-bold">
                    Doctor
                </label>

                <select name="DoctorId"
                        id="doctorDropdown"
                        class="form-select select2">

                    <option value="">
                        Search Doctor
                    </option>

                    @if (Model.Wizard.Doctors != null)
                    {
                        foreach (var item in Model.Wizard.Doctors)
                        {
                            <option value="@item.Id"
                                @(Model.DoctorId.ToString() == item.Id ? "selected" : "")>
                                @(item.Name ?? "N/A")
                            </option>
                        }
                    }

                </select>
            </div>

        </div>

        @if (Model.Wizard.SelectedDoctor != null)
        {
            var doc = Model.Wizard.SelectedDoctor;
            <div class="card shadow-lg border-0 rounded-4 mt-5 p-4">

                <!-- Doctor Info -->
                <div class="row">
                    <div class="col-md-3 text-center">
                        <img src="@doc.ImageUrl"
                             style="width:180px;height:180px;object-fit:cover;border-radius:50%;" />
                        <div class="mt-2">
                            <span class="badge bg-warning text-dark">⭐ @(doc.Rating ?? "N/A")</span>
                            <span class="text-muted ms-1" style="font-size:12px;">(@(doc.Review ?? "0") reviews)</span>
                        </div>
                        @if (doc.IsTeleconsult)
                        {
                            <div class="mt-2">
                                <span class="badge bg-success">Teleconsultation Available</span>
                            </div>
                        }
                    </div>

                    <div class="col-md-9">s
                        <h3>@doc.Name</h3>
                        @*<p class="text-muted mb-1">@(doc.Designation ?? "") |@(doc.DepartmentName ?? "")</p>    @(doc.Designation ?? "") | *@
                        <p class="text-muted mb-3">@(doc.SpecialisationName ?? "")</p>

                        <div class="row g-2">
                            <div class="col-md-6">
                                <strong>Experience:</strong>
                                <span>@doc.Experience</span>
                            </div>
                            <div class="col-md-6">
                                <strong>Consultation Fee:</strong>
                                <span class="text-success fw-bold">₹ @Model.Wizard.ConsultationAmount</span>
                            </div>
                            <div class="col-md-6">
                                <strong>Next Available:</strong>
                                <span>@doc.Timing</span>
                            </div>
                           @*  <div class="col-md-6">
                                <strong>Gender:</strong>
                                <span>@(doc.Gender == "M" ? "Male" : doc.Gender == "F" ? "Female" : doc.Gender == "B" ? "Both" : "N/A")</span>
                            </div> *@
                            @if (!string.IsNullOrWhiteSpace(doc.Treatment))
                            {
                                <div class="col-md-12">
                                    <strong>Treatments:</strong>
                                    <span>@doc.Treatment</span>
                                </div>
                            }
                            @if (doc.ConsultingHospitals.Any())
                            {
                                <div class="col-md-12">
                                    <strong>Hospital:</strong>
                                    <span>
                                        @doc.ConsultingHospitals.First().FacilityName,
                                        @doc.ConsultingHospitals.First().CityName
                                    </span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <!-- Calendar + Slots -->
                <div class="row g-4">

                    <!-- Calendar -->
                    <div class="col-md-4">
                        <h5 class="mb-3">Select Date</h5>
                        <input type="text"
                               id="slotCalendar"
                               class="form-control"
                               placeholder="Select date"
                               readonly />
                    </div>

                    <!-- Slots -->
                    <div class="col-md-8">
                        <h5 class="mb-3">
                            Available Slots
                            <span id="slotDateLabel" class="text-muted fs-6 ms-2"></span>
                        </h5>

                        <div id="slotsContainer" class="d-flex flex-wrap gap-2">
                            @if (Model.Wizard.Slots.Any())
                            {
                                foreach (var slot in Model.Wizard.Slots)
                                {
                                    var slotTime = DateTime.TryParse(slot.StartTime, out var t)
                                        ? t.ToString("hh:mm tt") : slot.StartTime;
                                    var slotDate = DateTime.TryParse(slot.StartTime, out var d)
                                        ? d.ToString("dd MMM yyyy") : "";

                                    <button type="button"
                                            class="btn btn-outline-primary rounded-pill px-3 py-1 slot-btn"
                                            style="font-size:13px;"
                                            data-start="@slot.StartTime"
                                            data-end="@slot.EndTime">
                                        <div>@slotTime</div>
                                        <div style="font-size:10px;color:#888;">@slotDate</div>
                                    </button>
                                }
                            }
                            else
                            {
                                <div class="text-muted">No slots available for today.</div>
                            }
                        </div>
                    </div>

                </div>

                <!-- Hidden fields -->
                <input type="hidden" id="hdnHospitalLocationId" value="@doc.HospitalLocationId" />
                <input type="hidden" id="hdnDoctorIdForSlot" value="@Model.DoctorId" />
                <input type="hidden" id="hdnFacilityIdForSlot" value="@Model.FacilityId" />

                <div class="text-end mt-5">
                    <button type="button"
                            class="btn btn-primary px-5 py-3 rounded-pill"
                            id="continueBtn">
                        Continue →
                    </button>
                </div>

            </div>
        }

    </div>
</form>


@section Scripts {
    <script>
        window.AppointmentConfig = {
            facilityId: '@Model.FacilityId',
            specialityId: '@Model.SpecialityId',
            doctorId: @(Model.DoctorId ?? 0)
        };
    </script>
    <script src="~/js/pages/appointment-validation.js"></script>
    <script src="~/js/pages/appointment.js"></script>
}

