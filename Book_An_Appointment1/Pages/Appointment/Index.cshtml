@page
@model Book_An_Appointment1.Pages.Appointment.IndexModel
@{
    ViewData["Title"] = "Book Appointment";
}

<form method="post">
    @Html.AntiForgeryToken()
    <div class="container mt-5">

        @* Error Message *@

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger mb-4">
                <strong>Error:</strong> @Model.ErrorMessage
            </div>
        }
        <!-- Tracker -->
        <div class="wizard-track mb-5 d-flex justify-content-between">

            <div class="step active">
                Appointment
            </div>

            <div class="step-line"></div>

            <div class="step">
                Patient Details
            </div>

            <div class="step-line"></div>

            <div class="step">
                Confirmation
            </div>

            <div class="step-line"></div>

            <div class="step">
                Payment
            </div>

        </div>

        <!-- Dropdowns -->
        <div class="row g-4">

            <!-- Facility -->
            <div class="col-md-4">
                <label class="form-label fw-bold">
                    Facility
                </label>

                <select name="FacilityId"
                        id="facilityDropdown"
                        class="form-select select2">

                    <option value="">
                        Select Facility
                    </option>

                    @foreach (var item in Model.Wizard.Facilities)
                    {
                        <option value="@item.FacilityId">
                            @(item.FacilityName ?? "N/A")
                        </option>
                    }

                </select>
            </div>

            <!-- Speciality -->
            <div class="col-md-4">
                <label class="form-label fw-bold">
                    Speciality
                </label>

                <select name="SpecialityId"
                        id="specialityDropdown"
                        class="form-select select2">

                    <option value="">
                        Search Speciality
                    </option>

                    @foreach (var item in Model.Wizard.Specialities)
                    {
                        <option value="@item.Id">
                            @(item.SpecialisationName ?? "N/A")
                        </option>
                    }

                </select>
            </div>

            <!-- Doctor -->
            <div class="col-md-4">
                <label class="form-label fw-bold">
                    Doctor
                </label>

                <select name="DoctorId"
                        id="doctorDropdown"
                        class="form-select select2">

                    <option value="">
                        Search Doctor
                    </option>

                    @if (Model.Wizard.Doctors != null)
                    {
                        foreach (var item in Model.Wizard.Doctors)
                        {
                            <option value="@item.Id"
                                @(Model.DoctorId.ToString() == item.Id ? "selected" : "")>
                                @(item.Name ?? "N/A")
                            </option>
                        }
                    }

                </select>
            </div>

        </div>

        @if (Model.Wizard.SelectedDoctor != null)
        {
            var doc = Model.Wizard.SelectedDoctor;
            <div class="card shadow-lg border-0 rounded-4 mt-5 p-4">

                <!-- Doctor Info -->
                <div class="row">
                    <div class="col-md-3 text-center">
                        <img src="@doc.ImageUrl"
                             style="width:180px;height:180px;object-fit:cover;border-radius:50%;" />

                        @*  <div class="doctor-summary mt-3 px-2">
                            <p class="summary-text">
                                @doc.Name
                                @if (!string.IsNullOrWhiteSpace(doc.Education))
                                {
                                    <span>@doc.Education</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(doc.SpecialisationName))
                                {
                                    <span class="d-block text-primary mt-1" style="font-size:12px;">
                                        @doc.SpecialisationName
                                    </span>
                                }
                            </p>
                        </div> *@
                        <div class="doctor-summary mt-3 px-2">
                            <p class="summary-text summary-truncate" title="@doc.Name
                                @(!string.IsNullOrWhiteSpace(doc.Education) ? "Education: " + doc.Education : "")
                                @(!string.IsNullOrWhiteSpace(doc.SpecialisationName) ? "Specialization: " + doc.SpecialisationName : "")
                                @(!string.IsNullOrWhiteSpace(doc.WorkExperience) ? "Experience: " + doc.WorkExperience : "Work Experience: 5 Years")
                                @(doc.ConsultingHospitals.Any() ? "Hospital: " + doc.ConsultingHospitals.First().FacilityName + "," + doc.ConsultingHospitals.First().CityName : "")">

                                <strong>@doc.Name</strong>

                                @* @if (!string.IsNullOrWhiteSpace(doc.Education))
                                {
                                    <span> holds <em>@doc.Education</em></span>
                                } *@

                                @if (!string.IsNullOrWhiteSpace(doc.SpecialisationName))
                                {
                                    <span>Specialization in <strong>@doc.SpecialisationName</strong></span>
                                }

                                @* @if (doc.ConsultingHospitals.Any())
                                {
                                     <span>
                                        , practicing at
                                        <strong>@doc.ConsultingHospitals.First().FacilityName</strong>,
                                        @doc.ConsultingHospitals.First().CityName
                                    </span> 
                                }*@

                                @* @if (!string.IsNullOrWhiteSpace(doc.WorkExperience))
                                {
                                    <span>, <strong>@doc.WorkExperience</strong> experience</span>
                                } *@
                            </p>
                        </div>

                        @*  <div class="doctor-summary mt-3 px-2">
                            <p class="summary-text">
                                <strong>@doc.Name</strong>

                                @if (!string.IsNullOrWhiteSpace(doc.Education))
                                {
                                    <span>holds <em>@doc.Education</em></span>
                                }

                                @if (!string.IsNullOrWhiteSpace(doc.SpecialisationName))
                                {
                                    <span>, specializing in <strong>@doc.SpecialisationName</strong></span>
                                }

                                @if (!string.IsNullOrWhiteSpace(doc.WorkExperience))
                                {
                                    <span> with <strong>@doc.WorkExperience</strong> of experience</span>
                                }

                                @if (doc.ConsultingHospitals.Any())
                                {
                                    <span>
                                        , currently practicing at
                                        <strong>@doc.ConsultingHospitals.First().FacilityName</strong>,
                                        @doc.ConsultingHospitals.First().CityName
                                    </span>
                                }

                                @if (!string.IsNullOrWhiteSpace(doc.ProfessionalStatement))
                                {
                                    <span class="d-block mt-1 fst-italic text-muted">
                                        "@doc.ProfessionalStatement"
                                    </span>
                                }
                            </p>
                        </div> *@

                        <div class="mt-2">
                            <span class="badge bg-warning text-dark">⭐ @(doc.Rating ?? "N/A")</span>
                            <span class="text-muted ms-1" style="font-size:12px;">(@(doc.Review ?? "0") reviews)</span>
                        </div>
                        @if (doc.IsTeleconsult)
                        {
                            <div class="mt-2">
                                <span class="badge bg-success">Teleconsultation Available</span>
                            </div>
                        }
                    </div>

                    <div class="col-md-9">
                        <h3>@doc.Name</h3>
                        @*<p class="text-muted mb-1">@(doc.Designation ?? "") |@(doc.DepartmentName ?? "")</p>    @(doc.Designation ?? "") | *@
                        <p class="text-muted mb-3">@(doc.SpecialisationName ?? "")</p>

                        <div class="row g-2">
                            <div class="col-md-6">
                                <strong>Experience:</strong>
                                <span>@doc.Experience</span>
                            </div>
                            <div class="col-md-6">
                                <strong>Consultation Fee:</strong>
                                <span class="text-success fw-bold">₹ @Model.Wizard.ConsultationAmount</span>
                            </div>
                            <div class="col-md-6">
                                <strong>Next Available:</strong>
                                <span>@doc.Timing</span>
                            </div>
                            @*  <div class="col-md-6">
                                <strong>Gender:</strong>
                                <span>@(doc.Gender == "M" ? "Male" : doc.Gender == "F" ? "Female" : doc.Gender == "B" ? "Both" : "N/A")</span>
                            </div> *@
                            @if (!string.IsNullOrWhiteSpace(doc.Treatment))
                            {
                                <div class="col-md-12">
                                    <strong>Treatments:</strong>
                                    <span>@doc.Treatment</span>
                                </div>
                            }
                            @if (doc.ConsultingHospitals.Any())
                            {
                                <div class="col-md-12">
                                    <strong>Hospital:</strong>
                                    <span>
                                        @doc.ConsultingHospitals.First().FacilityName,
                                        @doc.ConsultingHospitals.First().CityName
                                    </span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <!-- Calendar + Slots -->
                <div class="row g-4">

                    <!-- Calendar -->
                    <div class="col-md-4">
                        <h5 class="mb-3">Select Date</h5>
                        <input type="text"
                               id="slotCalendar"
                               class="form-control"
                               placeholder="Select date"
                               readonly />
                    </div>

                    <!-- Slots -->
                    <div class="col-md-8">
                        <h5 class="mb-3">
                            Available Slots
                            <span id="slotDateLabel" class="text-muted fs-6 ms-2"></span>
                        </h5>

                        <div id="slotsContainer" class="d-flex flex-wrap gap-2">
                            @if (Model.Wizard.Slots.Any())
                            {
                                foreach (var slot in Model.Wizard.Slots)
                                {
                                    var slotTime = DateTime.TryParse(slot.StartTime, out var t)
                                        ? t.ToString("hh:mm tt") : slot.StartTime;
                                    var slotDate = DateTime.TryParse(slot.StartTime, out var d)
                                        ? d.ToString("dd MMM yyyy") : "";

                                    <button type="button"
                                            class="btn btn-outline-primary rounded-pill px-3 py-1 slot-btn"
                                            style="font-size:13px;"
                                            data-start="@slot.StartTime"
                                            data-end="@slot.EndTime">
                                        <div>@slotTime</div>
                                        <div style="font-size:10px;color:#888;">@slotDate</div>
                                    </button>
                                }
                            }
                            else
                            {
                                <div class="text-muted">No slots available for today.</div>
                            }
                        </div>
                    </div>

                </div>

                <!-- Hidden fields -->
                <input type="hidden" id="hdnHospitalLocationId" value="@doc.HospitalLocationId" />
                <input type="hidden" id="hdnDoctorIdForSlot" value="@Model.DoctorId" />
                <input type="hidden" id="hdnFacilityIdForSlot" value="@Model.FacilityId" />

                <div class="text-end mt-5">
                    <button type="button" class="btn btn-primary px-5 py-3 rounded-pill" id="continueBtn" disabled>
                        Continue →
                    </button>
                </div>

            </div>
        }

    </div>
</form>



@section Scripts {
    <script>
        $(document).ready(function () {

            if (performance.navigation.type === 1) {
                window.location.href = window.location.pathname;
                return;
            }

            // Select2 initialize
            $('#facilityDropdown').select2({ width: '100%', placeholder: 'Select Facility' });
            $('#specialityDropdown').select2({ width: '100%', placeholder: 'Search Speciality' });
            $('#doctorDropdown').select2({ width: '100%', placeholder: 'Search Doctor' });

            // Selected values restore karo
            $('#facilityDropdown').val('@Model.FacilityId').trigger('change.select2');
            $('#specialityDropdown').val('@Model.SpecialityId').trigger('change.select2');

            @if (Model.DoctorId > 0)
            {
                            <text>
                                        $('#doctorDropdown').val('@Model.DoctorId').trigger('change.select2');
                                        initCalendar();
                            </text>
            }

            // Dropdown change events
            $('#facilityDropdown').on('change', function () { $('form').submit(); });
            $('#specialityDropdown').on('change', function () { $('form').submit(); });
            $('#doctorDropdown').on('change', function () { $('form').submit(); });

            // Slot select event
            $(document).on('click', '.slot-btn', function () {
                $('.slot-btn').removeClass('btn-primary').addClass('btn-outline-primary');
                $(this).removeClass('btn-outline-primary').addClass('btn-primary');
                $('#continueBtn').prop('disabled', false);
            });

        });

        function initCalendar() {
            flatpickr("#slotCalendar", {
                minDate: "today",
                dateFormat: "Y-m-d",
                defaultDate: "today",
                onChange: function (selectedDates, dateStr) {
                    loadSlots(dateStr);
                }
            });
        }

        function loadSlots(date) {
            var facilityId = $('#hdnFacilityIdForSlot').val();
            var doctorId = $('#hdnDoctorIdForSlot').val();
            var hospitalLocationId = $('#hdnHospitalLocationId').val();

            $('#slotsContainer').html('<div class="text-muted">Loading slots...</div>');
            $('#slotDateLabel').text('— ' + date);
            $('#continueBtn').prop('disabled', true);

            $.get('?handler=SlotsByDate', {
                facilityId: facilityId,
                doctorId: doctorId,
                hospitalLocationId: hospitalLocationId,
                date: date
            }, function (data) {
                $('#slotsContainer').empty();

                if (!data || data.length === 0) {
                    $('#slotsContainer').html('<div class="text-muted">No slots available for this date.</div>');
                    return;
                }

                $.each(data, function (i, slot) {
                    var parsed = new Date(slot.startTime.replace(' ', 'T'));
                    var timePart = isNaN(parsed)
                        ? slot.startTime
                        : parsed.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
                    var datePart = isNaN(parsed)
                        ? ''
                        : parsed.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });

                    $('#slotsContainer').append(
                        $('<button>', {
                            type: 'button',
                            class: 'btn btn-outline-primary rounded-pill px-3 py-1 slot-btn',
                            style: 'font-size:13px;',
                            'data-start': slot.startTime,
                            'data-end': slot.endTime
                        }).append(
                            $('<div>').text(timePart),
                            $('<div>', { style: 'font-size:10px;color:#888;' }).text(datePart)
                        )
                    );
                });
            });
        }
    </script>
}

